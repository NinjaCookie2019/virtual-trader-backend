APP_NAME=Virtual Trader
APP_ENV=development
APP_TIMEZONE=Asia/Kolkata
FRONTEND_ORIGIN=http://localhost:5173
RUNTIME_STATE_PATH=app/storage/runtime_state.json
TRADE_LEDGER_PATH=app/storage/trade_ledger.json

DHAN_CLIENT_ID=your_client_id
DHAN_ACCESS_TOKEN=your_access_token
DHAN_DISABLE_SSL=false
DHAN_AUTO_RENEW_ENABLED=true
DHAN_TOKEN_CHECK_SECONDS=1800
DHAN_TOKEN_RENEW_BUFFER_MINUTES=90
DHAN_TOKEN_STATE_PATH=app/storage/dhan_token.json

UNDERLYING_NAME=NIFTY 50
UNDERLYING_SECURITY_ID=13
UNDERLYING_EXCHANGE_SEGMENT=IDX_I
UNDERLYING_INSTRUMENT_TYPE=INDEX

DEFAULT_LOTS=1
DEFAULT_LOT_SIZE=65
DEFAULT_CAPITAL_SIZING_ENABLED=true
DEFAULT_ACCOUNT_CAPITAL=20000
DEFAULT_TRADE_CAPITAL=10000
DEFAULT_PRODUCT_TYPE=INTRADAY
DEFAULT_STRATEGY_ENABLED=true
DEFAULT_PAPER_TRADING=true
DEFAULT_MAX_TRADES_PER_DAY=2
DEFAULT_COOLDOWN_SECONDS=120
DEFAULT_BREAKOUT_BUFFER=0
DEFAULT_NO_TRADE_BEFORE_TIME=09:20
DEFAULT_OI_CONFIRMATION_MIN_EDGE_CHANGE_OI=650000
DEFAULT_OI_CONFIRMATION_MIN_EDGE_PERCENT=12
DEFAULT_STOP_LOSS_PERCENT=15
DEFAULT_TARGET_PERCENT=30
DEFAULT_TRAILING_STOP_ENABLED=true
DEFAULT_TRAILING_ACTIVATION_PERCENT=15
DEFAULT_TRAILING_DISTANCE_PERCENT=10
DEFAULT_AUTO_CLOSE_ENABLED=true
DEFAULT_AUTO_CLOSE_TIME=15:15
DEFAULT_REVERSE_SIGNAL_EXIT_ENABLED=false
STRIKE_STEP=50
OPTION_CHAIN_POLL_SECONDS=3.2
OPTION_QUOTE_POLL_SECONDS=2.0
